pipeline {
  agent {
    kubernetes {
      label "node-kaniko-${UUID.randomUUID().toString()}"
      defaultContainer 'node'
      yaml """
apiVersion: v1
kind: Pod
spec:
  restartPolicy: Never
  containers:
    - name: node
      image: node:22.17.1-bullseye
      command: ['cat']
      tty: true
    - name: kaniko
      image: gcr.io/kaniko-project/executor:debug
      command: ['/busybox/sh','-c','sleep infinity']
      tty: true
      volumeMounts:
        - name: docker-config
          mountPath: /kaniko/.docker
        - name: workspace
          mountPath: /workspace
    - name: kubectl
      image: bitnami/kubectl:latest
      command: ['sleep', 'infinity']
      securityContext:
        runAsUser: 0
  volumes:
    - name: workspace
      emptyDir: {}
    - name: docker-config
      secret:
        secretName: dockerhub-cred
        items:
          - key: .dockerconfigjson
            path: config.json
"""
    }
  }

  environment {
    IMAGE_NAME = 'seungwoo0128/dndn-frontend'
  }

  stages {
    stage('Prepare') {
      steps {
        script {
          // BRANCH_NAME은 Multibranch에서만 보통 설정됨. 일반 Pipeline은 checkout만 main이고 BRANCH_NAME이 비어 있을 수 있음.
          def gitShort = (env.GIT_BRANCH ?: '')
            .replaceFirst(/^refs\/heads\//, '')
            .replaceFirst(/^origin\//, '')
          def isMain = (env.BRANCH_NAME == 'main') || (gitShort == 'main')
          env.TARGET_NAMESPACE = isMain ? 'default' : 'test'
          env.IMAGE_TAG = isMain ? "2.${env.BUILD_NUMBER}" : "test-2.${env.BUILD_NUMBER}"
        }
      }
    }

    stage('Gradle Build') {
      steps {
        container('node') {
          sh '''
            npm i
            npm run build
          '''
        }
      }
    }

    stage('Kaniko Build & Push') {
      steps {
        container('kaniko') {
          sh """
            /kaniko/executor \
              --context=${WORKSPACE} \
              --dockerfile=${WORKSPACE}/Dockerfile \
              --destination=${env.IMAGE_NAME}:${env.IMAGE_TAG} \
              --destination=${env.IMAGE_NAME}:latest \
              --single-snapshot \
              --use-new-run \
              --cache=true \
              --snapshotMode=redo
          """
        }
      }
    }

    stage('Result') {
      steps {
        echo "Pushed: ${env.IMAGE_NAME}:${env.IMAGE_TAG}"
        echo "Deploying to Namespace: ${env.TARGET_NAMESPACE}"
      }
    }

    stage('Deploy to Kubernetes') {
      steps {
        container('kubectl'){
          script {
            // -n 옵션을 통해 TARGET_NAMESPACE에 배포하도록 수정
            sh "kubectl set image deployment/dndn-frontend frontend=${env.IMAGE_NAME}:${env.IMAGE_TAG} -n ${env.TARGET_NAMESPACE}"
            sh "kubectl rollout restart deployment/dndn-frontend -n ${env.TARGET_NAMESPACE}"
          }
        }
      }
    }
  }
}